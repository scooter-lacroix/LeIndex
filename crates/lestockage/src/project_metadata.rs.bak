    /// Load existing project IDs for a given base name
    ///
    /// # Arguments
    ///
    /// * `base_name` - Project base name
    ///
    /// # Returns
    ///
    /// `Result<Vec<UniqueProjectId>>` - All existing IDs with this base name
    pub fn load_existing_ids(&self, base_name: &str) -> Result<Vec<UniqueProjectId>> {
        let mut stmt = self.conn().prepare(
            "SELECT unique_project_id FROM project_metadata WHERE base_name = ?1",
        )?;

        let id_results: Vec<Result<UniqueProjectId, rusqlite::Error>> = stmt
            .query_map(params![base_name], |row| {
                let id_str: String = row.get(0)?;
                Ok(UniqueProjectId::from_str(&id_str))
            })
            .collect();

        // Filter out errors (from invalid ID strings) and collect valid IDs
        let ids: Vec<UniqueProjectId> = id_results
            .into_iter()
            .filter_map(|r| r.ok())
            .collect();

        Ok(ids)
    }